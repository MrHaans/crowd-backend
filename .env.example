# ============================================================
#  CROWD Protocol — X-Claim Backend
#  Copy file ini ke .env dan isi semua value
# ============================================================

# ── DATABASE ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/crowd_xclaim

# ── CRONOS RPC ───────────────────────────────────────────────
CRONOS_RPC_URL=https://evm.cronos.org          # Mainnet
# CRONOS_RPC_URL=https://evm-t3.cronos.org     # Testnet (untuk development)

# ── SMART CONTRACT ───────────────────────────────────────────
CONTRACT_ADDRESS=0x...                          # address setelah deploy CrowdRewardClaimer.sol
ORACLE_PRIVATE_KEY=0x...                        # private key wallet oracle (JANGAN COMMIT KE GIT)

# ── ANTHROPIC (tweet generator) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── X / TWITTER (READ ONLY — gratis, tanpa approval) ────────
# Hanya butuh Bearer Token untuk READ tweet (verify URL)
# Daftar di developer.x.com → Free tier → sudah bisa read
X_BEARER_TOKEN=AAAA...

# ── APP CONFIG ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development
API_SECRET=random-secret-untuk-sign-internal-request

# ── REWARD CONFIG (harus sama dengan smart contract) ─────────
REWARD_AMOUNT_CROWD=50          # $CROWD per claim
COOLDOWN_HOURS=24
CLAIM_WINDOW_HOURS=24
MIN_AGENT_FUEL=20
